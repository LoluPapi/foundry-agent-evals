# Copy to .env and fill in. Never commit .env.

# mode: "mock" (free, canned) | "openai" (OpenAI-compatible) | "azure" (Azure OpenAI)
AGENT_MODE=mock

# --- openai-compatible (Foundry Local, generic OpenAI-compatible servers) ---
# Foundry Local example:
# OPENAI_BASE_URL=http://localhost:5273/v1
# OPENAI_API_KEY=not-needed-for-local
# MODEL=phi-4-mini

# --- azure (Azure AI Foundry / Azure OpenAI) ---
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=<key>
# AZURE_OPENAI_API_VERSION=2024-10-21
# MODEL=gpt-4o-mini            # your deployment name

# Model used to grade open-ended cases (defaults to MODEL if unset)
# JUDGE_MODEL=gpt-4o-mini

# Quality gate: minimum pass rate for non-blocking cases (0.0 - 1.0)
PASS_THRESHOLD=0.8
